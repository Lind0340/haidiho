# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (HaiBot / DiHoBot / neighborhood AI moderator — server only)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (transactional mail + optional Supabase Auth SMTP)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@haidiho.com
RESEND_AUDIENCE_ID=
NEWSLETTER_REPLY_TO=wade@haidiho.com
NEWSLETTER_TEST_EMAIL=wade.lindgren@gmail.com
MODERATION_ALERT_EMAIL=wade@haidiho.com
# Auth emails: paste supabase/email-templates/*.html in Supabase Dashboard.
# For From: "Haidiho <hello@haidiho.com>", enable custom SMTP (see supabase/email-templates/README.md).

# App (required on Vercel — used in emails, auth redirects, OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Email images always load from this origin (defaults to https://haidiho.com if unset)
EMAIL_ASSET_BASE_URL=https://haidiho.com

# --- Vercel + Resend (Production) ---
# 1. Vercel → Project → Settings → Environment Variables (Production + Preview):
#    RESEND_API_KEY          from Resend dashboard or Vercel Resend integration
#    RESEND_FROM_EMAIL       hello@haidiho.com  (must be verified in Resend)
#    NEXT_PUBLIC_SITE_URL    https://haidiho.com
#    NEXT_PUBLIC_SUPABASE_*  + SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY, etc.
# 2. Resend → Domains → verify haidiho.com (SPF/DKIM) before sending from production.
# 3. Optional: Supabase Auth → SMTP → smtp.resend.com (same API key) for confirm emails.
# 4. Run supabase/migrate-email-log.sql in Supabase SQL editor.

# Stripe (merch — when launched)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Print on demand (optional)
PRINTFUL_API_KEY=
